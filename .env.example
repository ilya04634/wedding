# =============================================================================
# Google Service Account
# =============================================================================

CLIENT_EMAIL=
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

SPREADSHEET_ID=

# Фото/видео с банкета (Шаг 4)
FOLDER_ID=

# AI-фоны приглашений (если пусто — используется FOLDER_ID)
INVITE_BG_FOLDER_ID=

# Optional Drive OAuth for personal Google Drive uploads.
# Use this when Google Drive upload fails with:
# "Service Accounts do not have storage quota".
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=

GUESTS_SHEET_NAME=Guests
RSVP_SHEET_NAME=RSVP
SETTINGS_SHEET_NAME=Settings

# =============================================================================
# AI-фоны (DALL-E 3 → Google Drive)
# =============================================================================

OPENAI_API_KEY=
# Optional. Default: gpt-image-1. Use dall-e-3 only if GPT Image is unavailable.
OPENAI_IMAGE_MODEL=gpt-image-1
GENERATE_BG_WEBHOOK_SECRET=
ADMIN_PASSWORD=

# После деплоя — для Apps Script
SITE_URL=https://your-app.vercel.app
